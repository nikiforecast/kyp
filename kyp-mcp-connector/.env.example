# Journey Studio MCP Connector - Environment Variables
# Copy to .env and fill in your values

# Required: API key for authenticating MCP requests.
# When adding the connector in Claude Cowork, use this as the authorization_token.
JS_MCP_API_KEY=your-secret-api-key
# Legacy alias — still supported if JS_MCP_API_KEY is not set
# KYP_MCP_API_KEY=your-secret-api-key

# Required: Supabase project credentials.
# Use the Service Role key (not anon key) for server-side access.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Server configuration
PORT=3100
HOST=0.0.0.0

# Optional: For production with custom domain, allow these hosts (comma-separated)
# ALLOWED_HOSTS=localhost,journey-studio.example.com
